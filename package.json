{
  "name": "svg-eslint-parser",
  "version": "0.2.0",
  "description": "An SVG parser that produces output compatible with ESLint.",
  "keywords": [
    "eslint-parser",
    "parser",
    "svg"
  ],
  "homepage": "https://github.com/ntnyq/svg-eslint-parser#readme",
  "bugs": {
    "url": "https://github.com/ntnyq/svg-eslint-parser/issues"
  },
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "repository": "ntnyq/svg-eslint-parser",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "deploy": "run-s build docs:build",
    "dev": "tsdown --watch",
    "docs:build": "pnpm -C docs run build",
    "docs:dev": "pnpm -C docs run dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-s format:check lint typecheck test",
    "release:version": "bumpp",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@ntnyq/utils": "^0.15.0",
    "eslint-visitor-keys": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@typescript/native-preview": "^7.0.0-dev.20260607.1",
    "@vitest/coverage-v8": "^4.1.8",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx,vue}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@11.5.2"
}
